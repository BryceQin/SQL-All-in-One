{
    "Select All": {
        "prefix": "sel",
        "body": [
            "SELECT",
            "    $1",
            "FROM $2",
            "WHERE $3",
            "LIMIT 100;"
        ],
        "description": "Basic SELECT statement"
    },
    "Select Distinct": {
        "prefix": "seld",
        "body": [
            "SELECT DISTINCT",
            "    $1",
            "FROM $2",
            "WHERE $3",
            "LIMIT 100;"
        ],
        "description": "SELECT with DISTINCT"
    },
    "Join Tables": {
        "prefix": "join",
        "body": [
            "SELECT",
            "    $1",
            "FROM $2",
            "JOIN $3 ON $2.$4 = $3.$5",
            "WHERE $6",
            "LIMIT 100;"
        ],
        "description": "JOIN tables"
    },
    "Left Join": {
        "prefix": "leftjoin",
        "body": [
            "SELECT",
            "    $1",
            "FROM $2",
            "LEFT JOIN $3 ON $2.$4 = $3.$5",
            "WHERE $6",
            "LIMIT 100;"
        ],
        "description": "LEFT JOIN tables"
    },
    "Group By": {
        "prefix": "groupby",
        "body": [
            "SELECT",
            "    $1,",
            "    COUNT(*) AS cnt",
            "FROM $2",
            "WHERE $3",
            "GROUP BY $1",
            "HAVING $4",
            "ORDER BY cnt DESC",
            "LIMIT 100;"
        ],
        "description": "Group By with aggregation"
    },
    "Case When": {
        "prefix": "case",
        "body": [
            "CASE",
            "    WHEN $1 THEN $2",
            "    WHEN $3 THEN $4",
            "    ELSE $5",
            "END AS $6"
        ],
        "description": "CASE WHEN statement"
    },
    "Insert Into": {
        "prefix": "insert",
        "body": [
            "INSERT INTO $1 ($2)",
            "VALUES",
            "    ($3);"
        ],
        "description": "INSERT INTO statement"
    },
    "Insert Select": {
        "prefix": "insertsel",
        "body": [
            "INSERT INTO $1 ($2)",
            "SELECT",
            "    $3",
            "FROM $4",
            "WHERE $5;"
        ],
        "description": "INSERT ... SELECT statement"
    },
    "Update": {
        "prefix": "update",
        "body": [
            "UPDATE $1",
            "SET $2 = $3",
            "WHERE $4;"
        ],
        "description": "UPDATE statement"
    },
    "Delete": {
        "prefix": "delete",
        "body": [
            "DELETE FROM $1",
            "WHERE $2;"
        ],
        "description": "DELETE statement"
    },
    "Create Table": {
        "prefix": "ct",
        "body": [
            "CREATE TABLE $1 (",
            "    id BIGINT COMMENT '主键ID',",
            "    $2",
            "    created_at TIMESTAMP COMMENT '创建时间'",
            ") COMMENT '$3';",
            "$0"
        ],
        "description": "Create Table statement"
    },
    "Create Table As Select": {
        "prefix": "ctas",
        "body": [
            "CREATE TABLE $1 AS",
            "SELECT",
            "    $2",
            "FROM $3",
            "WHERE $4;"
        ],
        "description": "CREATE TABLE AS SELECT"
    },
    "With CTE": {
        "prefix": "with",
        "body": [
            "WITH $1 AS (",
            "    SELECT $2 FROM $3 WHERE $4",
            ")",
            "SELECT $5",
            "FROM $1",
            "WHERE $6",
            "LIMIT 100;"
        ],
        "description": "WITH common table expression"
    },
    "Union All": {
        "prefix": "union",
        "body": [
            "SELECT $1 FROM $2",
            "UNION ALL",
            "SELECT $3 FROM $4"
        ],
        "description": "UNION ALL"
    },
    "Hive Partition Insert": {
        "prefix": "hivepart",
        "body": [
            "INSERT OVERWRITE TABLE $1",
            "PARTITION ($2 = '$3')",
            "SELECT",
            "    $4",
            "FROM $5",
            "WHERE $6;"
        ],
        "description": "Hive partition insert"
    },
    "Hive Select Partition": {
        "prefix": "hiveselpart",
        "body": [
            "SELECT",
            "    $1",
            "FROM $2",
            "WHERE $3 = '$4'",
            "LIMIT 100;"
        ],
        "description": "Hive select from partition"
    },
    "Comment Header": {
        "prefix": "comment",
        "body": [
            "-- ===========================================",
            "-- Description: $1",
            "-- Author: ${2:Your Name}",
            "-- Date: $CURRENT_YEAR-$CURRENT_MONTH-$CURRENT_DATE",
            "-- ===========================================",
            "$0"
        ],
        "description": "Comment header for SQL"
    }
}
