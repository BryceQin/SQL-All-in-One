{
    "Oracle PL/SQL Anonymous Block": {
        "prefix": "orplsql",
        "body": [
            "DECLARE",
            "    $1 $2;",
            "BEGIN",
            "    $3;",
            "EXCEPTION",
            "    WHEN OTHERS THEN",
            "        $4;",
            "END;",
            "/"
        ],
        "description": "Oracle PL/SQL anonymous block"
    },
    "Oracle Create Package": {
        "prefix": "orpkg",
        "body": [
            "CREATE OR REPLACE PACKAGE $1",
            "AS",
            "    $2",
            "END $1;",
            "/"
        ],
        "description": "Create Oracle package"
    },
    "Oracle Connect By": {
        "prefix": "orconnect",
        "body": [
            "SELECT $1",
            "FROM $2",
            "START WITH $3",
            "CONNECT BY PRIOR $4 = $5;"
        ],
        "description": "Oracle CONNECT BY hierarchical query"
    },
    "Oracle Merge": {
        "prefix": "ormerge",
        "body": [
            "MERGE INTO $1 t",
            "USING $2 s",
            "ON ($3)",
            "WHEN MATCHED THEN UPDATE SET $4",
            "WHEN NOT MATCHED THEN INSERT ($5) VALUES ($6);"
        ],
        "description": "Oracle MERGE statement"
    },
    "Oracle Hint": {
        "prefix": "orhint",
        "body": [
            "SELECT /*+ $1 */ $2",
            "FROM $3 t;"
        ],
        "description": "Oracle optimizer hint"
    },
    "Oracle Decode": {
        "prefix": "ordecode",
        "body": [
            "DECODE($1, $2, $3, $4, $5, $6)"
        ],
        "description": "Oracle DECODE function"
    },
    "Oracle Select From Dual": {
        "prefix": "ordual",
        "body": [
            "SELECT $1 FROM DUAL;"
        ],
        "description": "Oracle SELECT FROM DUAL"
    },
    "Oracle NVL": {
        "prefix": "ornvl",
        "body": [
            "NVL($1, $2)"
        ],
        "description": "Oracle NVL function"
    }
}
