{
    "Presto Array": {
        "prefix": "prestoarray",
        "body": [
            "ARRAY[$1]"
        ],
        "description": "Presto ARRAY"
    },
    "Presto Map": {
        "prefix": "prestomap",
        "body": [
            "MAP(ARRAY[$1], ARRAY[$2])"
        ],
        "description": "Presto MAP"
    },
    "Presto Unnest with Ordinality": {
        "prefix": "prestounnest",
        "body": [
            "CROSS JOIN UNNEST($1) WITH ORDINALITY AS t($2, $3)"
        ],
        "description": "Presto UNNEST WITH ORDINALITY"
    },
    "Presto Lambda": {
        "prefix": "prestolambda",
        "body": [
            "TRANSFORM($1, x -> x + 1)"
        ],
        "description": "Presto lambda expression"
    },
    "Presto At Time Zone": {
        "prefix": "prestotimezone",
        "body": [
            "AT TIME ZONE '$1'"
        ],
        "description": "Presto AT TIME ZONE"
    },
    "Presto Approx Distinct": {
        "prefix": "prestoapprox",
        "body": [
            "APPROX_DISTINCT($1)"
        ],
        "description": "Presto APPROX_DISTINCT"
    }
}
