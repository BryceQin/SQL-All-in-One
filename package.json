{
    "name": "hive-formatter",
    "displayName": "Hive Formatter",
    "description": "一个用于 Hive、MySQL、SparkSQL 格式化的 VSCode 插件，支持 SQL IntelliSense 智能补全、语法检查和 MySQL/HiveSQL 互相转换",
    "version": "0.20.0",
    "publisher": "bryce-qin",
    "contributors": [
        "TalDu"
    ],
    "license": "MIT",
    "icon": "hive-formatter-icon.png",
    "engines": {
        "vscode": "^1.85.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/BryceQin/Hive-Formatter"
    },
    "bugs": {
        "url": "https://github.com/BryceQin/Hive-Formatter/issues"
    },
    "categories": [
        "Formatters",
        "Snippets",
        "Other"
    ],
    "keywords": [
        "hive",
        "formatter",
        "mysql",
        "spark",
        "sparksql",
        "sql",
        "snippets"
    ],
    "activationEvents": [
        "onStartupFinished",
        "onLanguage:sql",
        "onLanguage:hive",
        "onLanguage:mysql",
        "onLanguage:spark",
        "onLanguage:postgresql",
        "onLanguage:oracle",
        "onLanguage:plsql",
        "onLanguage:bigquery",
        "onLanguage:snowflake",
        "onLanguage:presto",
        "onLanguage:sqlite"
    ],
    "main": "./out/extension.js",
    "browser": "./out/extension.js",
    "contributes": {
        "snippets": [
            { "language": "sql", "path": "./snippets/common.json" },
            { "language": "sql", "path": "./snippets/sql.json" },
            { "language": "hive", "path": "./snippets/common.json" },
            { "language": "hive", "path": "./snippets/hive.json" },
            { "language": "mysql", "path": "./snippets/common.json" },
            { "language": "mysql", "path": "./snippets/mysql.json" },
            { "language": "spark", "path": "./snippets/common.json" },
            { "language": "spark", "path": "./snippets/spark.json" },
            { "language": "postgresql", "path": "./snippets/common.json" },
            { "language": "postgresql", "path": "./snippets/postgresql.json" },
            { "language": "oracle", "path": "./snippets/common.json" },
            { "language": "oracle", "path": "./snippets/oracle.json" },
            { "language": "plsql", "path": "./snippets/common.json" },
            { "language": "plsql", "path": "./snippets/oracle.json" },
            { "language": "bigquery", "path": "./snippets/common.json" },
            { "language": "bigquery", "path": "./snippets/bigquery.json" },
            { "language": "snowflake", "path": "./snippets/common.json" },
            { "language": "snowflake", "path": "./snippets/snowflake.json" },
            { "language": "presto", "path": "./snippets/common.json" },
            { "language": "presto", "path": "./snippets/presto.json" },
            { "language": "sqlite", "path": "./snippets/common.json" },
            { "language": "sqlite", "path": "./snippets/sqlite.json" }
        ],
        "languages": [
            {
                "id": "sql",
                "aliases": ["SQL"],
                "extensions": [".sql"]
            },
            {
                "id": "hive",
                "aliases": ["Hive", "hive-sql"],
                "extensions": [".hql"]
            },
            {
                "id": "mysql",
                "aliases": ["MySQL"],
                "extensions": [".mysql"]
            },
            {
                "id": "spark",
                "aliases": ["SparkSQL", "spark"],
                "extensions": [".sparksql"]
            },
            {
                "id": "postgresql",
                "aliases": ["PostgreSQL", "postgres"],
                "extensions": [".psql", ".pgsql"]
            },
            {
                "id": "plsql",
                "aliases": ["Oracle", "PL/SQL"],
                "extensions": [".pls", ".plsql"]
            },
            {
                "id": "bigquery",
                "aliases": ["BigQuery"],
                "extensions": [".bqsql"]
            },
            {
                "id": "snowflake",
                "aliases": ["Snowflake"],
                "extensions": [".snowsql"]
            },
            {
                "id": "presto",
                "aliases": ["Presto", "Trino"],
                "extensions": [".prestosql"]
            },
            {
                "id": "sqlite",
                "aliases": ["SQLite"],
                "extensions": [".sqlite", ".sqlt"]
            }
        ],
        "commands": [
            {
                "title": "Format Selection (Hive Formatter)",
                "shortTitle": "Format Hive",
                "command": "hive-formatter.format-selection"
            },
            {
                "title": "MySQL to HiveSQL",
                "shortTitle": "MySQL to Hive",
                "command": "hive-formatter.mysql-to-hive"
            },
            {
                "title": "HiveSQL to MySQL",
                "shortTitle": "Hive to MySQL",
                "command": "hive-formatter.hive-to-mysql"
            },
            {
                "title": "Hive Formatter Config",
                "shortTitle": "Config Editor",
                "command": "hive-formatter.open-config-editor"
            },
            {
                "title": "Replace Parameter",
                "shortTitle": "Replace Param",
                "command": "hive-formatter.replaceParameter"
            },
            {
                "command": "hive-formatter.toggleComment",
                "title": "Hive Formatter: 切换注释"
            },
            {
                "command": "hive-formatter.toggleAdvancedComment",
                "title": "Hive Formatter: 切换高级注释"
            }
        ],
        "keybindings": [
            {
                "command": "hive-formatter.replaceParameter",
                "key": "ctrl+shift+r",
                "mac": "cmd+shift+r",
                "when": "editorLangId =~ /sql|hive/"
            },
            {
                "command": "hive-formatter.toggleComment",
                "key": "ctrl+/",
                "mac": "cmd+/",
                "when": "editorTextFocus && editorLangId =~ /sql|hive/"
            },
            {
                "command": "hive-formatter.toggleAdvancedComment",
                "key": "ctrl+shift+/",
                "mac": "cmd+shift+/",
                "when": "editorTextFocus && editorLangId =~ /sql|hive/"
            }
        ],
        "configuration": {
            "title": "Hive Formatter",
            "properties": {
                "Hive-Formatter.dialect": {
                "type": "string",
                "enum": [
                    "auto-detect",
                    "hive",
                    "mysql",
                    "spark",
                    "sql",
                    "postgresql",
                    "oracle",
                    "bigquery",
                    "snowflake",
                    "presto",
                    "sqlite"
                ],
                "enumDescriptions": [
                    "自动检测",
                    "Apache Hive",
                    "MySQL",
                    "Spark",
                    "Basic SQL - generally not recommended.",
                    "PostgreSQL",
                    "Oracle",
                    "BigQuery",
                    "Snowflake",
                    "Presto/Trino",
                    "SQLite"
                ],
                "default": "hive",
                "markdownDescription": "选择使用的SQL方言。强烈建议选择否则可能出错。"
            },
                "Hive-Formatter.displayLanguage": {
                    "type": "string",
                    "enum": ["auto", "zh", "en"],
                    "enumDescriptions": [
                        "%hive-formatter.config.displayLanguage.enumDescriptions.auto%",
                        "%hive-formatter.config.displayLanguage.enumDescriptions.zh%",
                        "%hive-formatter.config.displayLanguage.enumDescriptions.en%"
                    ],
                    "default": "auto",
                    "markdownDescription": "%hive-formatter.config.displayLanguage.markdownDescription%",
                    "order": 1
                },
                "Hive-Formatter.ignoreTabSettings": {
                    "type": "boolean",
                    "default": false,
                    "markdownDescription": "是否忽略用户和工作区设置的 `tabSize` 和 `insertSpaces` (使用 `#Hive-Formatter.tabSizeOverride#` 和 `#Hive-Formatter.insertSpacesOverride#`)?"
                },
                "Hive-Formatter.tabSizeOverride": {
                    "type": "number",
                    "default": 2,
                    "minimum": 1,
                    "markdownDescription": "当 `#Hive-Formatter.ignoreTabSettings#`激活时，覆盖 `tabSize` 设置，"
                },
                "Hive-Formatter.insertSpacesOverride": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "当 `#Hive-Formatter.ignoreTabSettings#`激活时，覆盖 `insertSpaces` 设置"
                },
                "Hive-Formatter.keywordCase": {
                    "type": "string",
                    "enum": [
                        "preserve",
                        "upper",
                        "lower"
                    ],
                    "default": "preserve",
                    "markdownDescription": "以大写、小写或保留现状来格式化关键字"
                },
                "Hive-Formatter.dataTypeCase": {
                    "type": "string",
                    "enum": [
                        "preserve",
                        "upper",
                        "lower"
                    ],
                    "default": "preserve",
                    "markdownDescription": "以大写、小写或保留现状来格式化数据类型"
                },
                "Hive-Formatter.functionCase": {
                    "type": "string",
                    "enum": [
                        "preserve",
                        "upper",
                        "lower"
                    ],
                    "default": "preserve",
                    "markdownDescription": "以大写、小写或保留现状来格式化函数名"
                },
                "Hive-Formatter.identifierCase": {
                    "type": "string",
                    "enum": [
                        "preserve",
                        "upper",
                        "lower"
                    ],
                    "default": "preserve",
                    "markdownDescription": "以大写、小写或保留现状来格式化标识符"
                },
                "Hive-Formatter.indentStyle": {
                    "type": "string",
                    "enum": [
                        "standard",
                        "tabularLeft",
                        "tabularRight"
                    ],
                    "enumDescriptions": [
                        "标准SQL格式，带有级联缩进",
                        "在关键字和参数之间保留空格列，使关键字左对齐",
                        "在关键字和参数之间保留空格列，将关键字向右对齐"
                    ],
                    "default": "standard",
                    "markdownDescription": "在标准关键词定位与保持中心位置列之间进行切换"
                },
                "Hive-Formatter.logicalOperatorNewline": {
                    "type": "string",
                    "enum": [
                        "before",
                        "after"
                    ],
                    "default": "before",
                    "markdownDescription": "是否在 AND 和 OR 之前或之后换行"
                },
                "Hive-Formatter.expressionWidth": {
                    "type": "integer",
                    "default": 50,
                    "minimum": 0,
                    "markdownDescription": "一对括号之间的字符数达到多少时，应将表达式拆分为多行"
                },
                "Hive-Formatter.linesBetweenQueries": {
                    "type": "integer",
                    "default": 1,
                    "minimum": 0,
                    "markdownDescription": "每个查询/语句之间应放置多少个换行符"
                },
                "Hive-Formatter.denseOperators": {
                    "type": "boolean",
                    "default": false,
                    "markdownDescription": "是否去除运算符（如+或>=）周围的空格"
                },
                "Hive-Formatter.newlineBeforeSemicolon": {
                    "type": "boolean",
                    "default": false,
                    "markdownDescription": "分号应另起一行还是放在上一行"
                },
                "Hive-Formatter.commaPosition": {
                    "type": "string",
                    "enum": [
                        "before",
                        "after"
                    ],
                    "default": "after",
                    "markdownDescription": "逗号位置：放在行首还是行尾"
                },
                "Hive-Formatter.alignColumnDefinitions": {
                    "type": "boolean",
                    "default": false,
                    "markdownDescription": "是否对齐列定义"
                },
                "Hive-Formatter.newlineAfterSelect": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "SELECT 关键字后是否换行"
                },
                "Hive-Formatter.newlineAfterFrom": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "FROM 关键字后是否换行"
                },
                "Hive-Formatter.newlineBeforeWhere": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "WHERE 关键字前是否换行"
                },
                "Hive-Formatter.newlineAfterWhere": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "WHERE 关键字后是否换行"
                },
                "Hive-Formatter.newlineBeforeOrderBy": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "ORDER BY 关键字前是否换行"
                },
                "Hive-Formatter.newlineBeforeGroupBy": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "GROUP BY 关键字前是否换行"
                },
                "Hive-Formatter.newlineBeforeHaving": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "HAVING 关键字前是否换行"
                },
                "Hive-Formatter.newlineBeforeLimit": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "LIMIT 关键字前是否换行"
                },
                "Hive-Formatter.maxLineLength": {
                    "type": "integer",
                    "default": 120,
                    "minimum": 40,
                    "maximum": 500,
                    "markdownDescription": "最大行长度"
                },
                "Hive-Formatter.tabulateAlias": {
                    "type": "boolean",
                    "default": false,
                    "markdownDescription": "是否对齐表别名"
                },
                "Hive-Formatter.reservedKeywordCase": {
                    "type": "string",
                    "enum": [
                        "preserve",
                        "upper",
                        "lower"
                    ],
                    "default": "preserve",
                    "markdownDescription": "保留关键字的大小写（SELECT, FROM, WHERE 等）"
                },
                "Hive-Formatter.builtinFunctionCase": {
                    "type": "string",
                    "enum": [
                        "preserve",
                        "upper",
                        "lower"
                    ],
                    "default": "preserve",
                    "markdownDescription": "内置函数的大小写（COUNT, SUM, MAX 等）"
                },
                "Hive-Formatter.newlineBeforeJoin": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "JOIN 关键字前是否换行"
                },
                "Hive-Formatter.newlineAfterComma": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "逗号后是否强制换行"
                },
                "Hive-Formatter.alignWhereClauses": {
                    "type": "boolean",
                    "default": false,
                    "markdownDescription": "WHERE 子句是否对齐"
                },
                "Hive-Formatter.alignCaseStatements": {
                    "type": "boolean",
                    "default": false,
                    "markdownDescription": "CASE 语句是否对齐"
                },
                "Hive-Formatter.breakAfterSelectItem": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "每个 SELECT 项后是否换行"
                },
                "Hive-Formatter.breakAfterFromItem": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "每个 FROM 项后是否换行"
                },
                "Hive-Formatter.spaceBeforeComma": {
                    "type": "boolean",
                    "default": false,
                    "markdownDescription": "逗号前是否加空格"
                },
                "Hive-Formatter.spaceInsideParentheses": {
                    "type": "boolean",
                    "default": false,
                    "markdownDescription": "括号内是否加空格"
                },
                "Hive-Formatter.trimTrailingSpaces": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "是否修剪尾部空格"
                },
                "Hive-Formatter.semicolonAtEnd": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "是否在语句结尾添加分号"
                },
                "Hive-Formatter.singleLineMaxLength": {
                    "type": "integer",
                    "default": 80,
                    "minimum": 40,
                    "maximum": 500,
                    "markdownDescription": "单行查询最大长度"
                },
                "Hive-Formatter.paramTypes": {
                    "type": "object",
                    "default": {},
                    "markdownDescription": "指定要支持的参数占位符类型"
                },
                "Hive-Formatter.enableEnhancedChecks": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "是否启用增强的语法检查功能"
                },
                "Hive-Formatter.showErrorLevel": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "是否显示错误级别的诊断信息"
                },
                "Hive-Formatter.showWarningLevel": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "是否显示警告级别的诊断信息"
                },
                "Hive-Formatter.showInfoLevel": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "是否显示信息级别的诊断提示"
                },
                "Hive-Formatter.enableLinter": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "是否启用 SQL Lint 功能"
                },
                "Hive-Formatter.lint.avoid_select_star": {
                    "type": "object",
                    "default": { "enabled": true, "severity": "warning" },
                    "markdownDescription": "配置 `avoid_select_star` 规则"
                },
                "Hive-Formatter.lint.explicit_join_type": {
                    "type": "object",
                    "default": { "enabled": true, "severity": "information" },
                    "markdownDescription": "配置 `explicit_join_type` 规则"
                },
                "Hive-Formatter.lint.limit_with_order_by": {
                    "type": "object",
                    "default": { "enabled": true, "severity": "warning" },
                    "markdownDescription": "配置 `limit_with_order_by` 规则"
                },
                "Hive-Formatter.lint.avoid_column_count_mismatch": {
                    "type": "object",
                    "default": { "enabled": true, "severity": "error" },
                    "markdownDescription": "配置 `avoid_column_count_mismatch` 规则"
                },
                "Hive-Formatter.lint.missing_primary_key": {
                    "type": "object",
                    "default": { "enabled": true, "severity": "warning" },
                    "markdownDescription": "配置 `missing_primary_key` 规则"
                },
                "Hive-Formatter.lint.use_current_timestamp": {
                    "type": "object",
                    "default": { "enabled": true, "severity": "information" },
                    "markdownDescription": "配置 `use_current_timestamp` 规则"
                },
                "Hive-Formatter.lint.avoid_select_in_insert": {
                    "type": "object",
                    "default": { "enabled": true, "severity": "warning" },
                    "markdownDescription": "配置 `avoid_select_in_insert` 规则"
                },
                "Hive-Formatter.lint.duplicate_column_aliases": {
                    "type": "object",
                    "default": { "enabled": true, "severity": "warning" },
                    "markdownDescription": "配置 \"duplicate_column_aliases\" 规则"
                },
                "Hive-Formatter.lint.uppercase_keywords": {
                    "type": "object",
                    "default": { "enabled": false, "severity": "information" },
                    "markdownDescription": "配置 \"uppercase_keywords\" 规则"
                },
                "Hive-Formatter.lint.consistent_aliasing": {
                    "type": "object",
                    "default": { "enabled": false, "severity": "information" },
                    "markdownDescription": "配置 \"consistent_aliasing\" 规则"
                },
                "Hive-Formatter.lint.use_coalesce_over_isnull": {
                    "type": "object",
                    "default": { "enabled": false, "severity": "information" },
                    "markdownDescription": "配置 \"use_coalesce_over_isnull\" 规则"
                },
                "Hive-Formatter.lint.explicit_column_aliasing": {
                    "type": "object",
                    "default": { "enabled": false, "severity": "information" },
                    "markdownDescription": "配置 \"explicit_column_aliasing\" 规则"
                },
                "Hive-Formatter.lint.avoid_correlated_subqueries": {
                    "type": "object",
                    "default": { "enabled": false, "severity": "warning" },
                    "markdownDescription": "配置 \"avoid_correlated_subqueries\" 规则"
                },
                "Hive-Formatter.lint.long_query_line": {
                    "type": "object",
                    "default": { "enabled": false, "severity": "information" },
                    "markdownDescription": "配置 \"long_query_line\" 规则"
                },
                "Hive-Formatter.enableCodeFolding": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "是否启用代码折叠功能"
                },
                "Hive-Formatter.enableOutlineView": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "是否启用大纲视图功能"
                },
                "Hive-Formatter.enableStatusBar": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "是否启用状态栏功能"
                },
                "Hive-Formatter.enableParameterHighlight": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "是否启用参数高亮和替换功能"
                },
                "Hive-Formatter.enableSnippets": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "是否启用代码片段功能"
                },
                "Hive-Formatter.enableQuickFix": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "是否启用快速修复功能"
                },
                "Hive-Formatter.enableCompletion": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "是否启用智能补全功能"
                },
                "Hive-Formatter.completion.keywords": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "补全列表中是否包含关键字"
                },
                "Hive-Formatter.completion.functions": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "补全列表中是否包含函数"
                },
                "Hive-Formatter.completion.snippets": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "补全列表中是否包含代码片段"
                },
                "Hive-Formatter.completion.cteNames": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "是否提示 CTE 名称"
                },
                "Hive-Formatter.completion.identifiers": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "是否提示表名和列名"
                },
                "Hive-Formatter.enableSmartCommentToggle": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "是否启用 SQL 感知的智能注释切换（关闭后回退到 VSCode 默认行为）"
                },
                "Hive-Formatter.headerAuthor": {
                    "type": "string",
                    "default": "",
                    "markdownDescription": "文件头注释中的作者名（为空时 header Snippet 的「作者」留空等待输入）"
                },
                "Hive-Formatter.headerModifier": {
                    "type": "string",
                    "default": "",
                    "markdownDescription": "文件头注释中的修改人（为空时回退取 headerAuthor 的值）"
                },
                "Hive-Formatter.completion.commentSnippets": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "补全列表中是否包含注释模板片段"
                },
                "Hive-Formatter.lint.missing_query_comment": {
                    "type": "object",
                    "default": { "enabled": true, "severity": "warning" },
                    "markdownDescription": "配置 `missing_query_comment` 规则（复杂查询缺少说明注释）"
                },
                "Hive-Formatter.lint.missing_query_comment_threshold_line_count": {
                    "type": "number",
                    "default": 20,
                    "markdownDescription": "触发 missing_query_comment 的最小查询行数"
                },
                "Hive-Formatter.lint.missing_query_comment_threshold_join_count": {
                    "type": "number",
                    "default": 3,
                    "markdownDescription": "触发 missing_query_comment 的最小 JOIN 数量"
                },
                "Hive-Formatter.lint.missing_query_comment_threshold_subquery_count": {
                    "type": "number",
                    "default": 2,
                    "markdownDescription": "触发 missing_query_comment 的最小子查询数量"
                },
                "Hive-Formatter.lint.missing_column_comment": {
                    "type": "object",
                    "default": { "enabled": true, "severity": "warning" },
                    "markdownDescription": "配置 `missing_column_comment` 规则（DDL 列定义缺少 COMMENT）"
                },
                "Hive-Formatter.lint.missing_column_comment_aggregate": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "同一 DDL 中多个缺失 COMMENT 的列是否聚合为一条诊断"
                },
                "Hive-Formatter.lint.missing_column_comment_external_table_exempt": {
                    "type": "boolean",
                    "default": false,
                    "markdownDescription": "外部表（EXTERNAL TABLE）是否豁免 missing_column_comment 检查"
                },
                "Hive-Formatter.lint.commented_out_code": {
                    "type": "object",
                    "default": { "enabled": true, "severity": "information" },
                    "markdownDescription": "配置 `commented_out_code` 规则（疑似注释掉的大段代码）"
                },
                "Hive-Formatter.lint.commented_out_code_threshold_lines": {
                    "type": "number",
                    "default": 3,
                    "markdownDescription": "触发 commented_out_code 的最小注释代码行数"
                },
                "Hive-Formatter.lint.expired_todo": {
                    "type": "object",
                    "default": { "enabled": true, "severity": "information" },
                    "markdownDescription": "配置 `expired_todo` 规则（过期的 TODO/FIXME 标记）"
                },
                "Hive-Formatter.lint.expired_todo_grace_period_days": {
                    "type": "number",
                    "default": 7,
                    "markdownDescription": "TODO 过期判定宽限期（天）"
                },
                "Hive-Formatter.nullCase": {
                    "type": "string",
                    "enum": ["preserve", "upper", "lower"],
                    "default": "preserve",
                    "markdownDescription": "NULL 关键字的大小写"
                },
                "Hive-Formatter.booleanCase": {
                    "type": "string",
                    "enum": ["preserve", "upper", "lower"],
                    "default": "preserve",
                    "markdownDescription": "TRUE / FALSE 关键字的大小写"
                },
                "Hive-Formatter.newlineAfterGroupBy": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "GROUP BY 后字段列表是否换行"
                },
                "Hive-Formatter.newlineAfterHaving": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "HAVING 后条件表达式是否换行"
                },
                "Hive-Formatter.newlineAfterOrderBy": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "ORDER BY 后排序列是否换行"
                },
                "Hive-Formatter.newlineAfterLimit": {
                    "type": "boolean",
                    "default": false,
                    "markdownDescription": "LIMIT 后数字是否换行"
                },
                "Hive-Formatter.newlineAfterJoin": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "JOIN 后表名/子查询是否换行"
                },
                "Hive-Formatter.newlineBeforeSetOperation": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "UNION / INTERSECT / EXCEPT 前是否换行"
                },
                "Hive-Formatter.newlineAfterSetOperation": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "集合操作关键字后是否换行"
                },
                "Hive-Formatter.newlineBeforeOn": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "JOIN ... ON 的 ON 关键字是否换行"
                },
                "Hive-Formatter.newlineBeforeUsing": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "JOIN ... USING 的 USING 关键字是否换行"
                },
                "Hive-Formatter.newlineBeforeWith": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "WITH 关键字前是否换行"
                },
                "Hive-Formatter.newlineAfterWith": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "WITH 关键字后（第一个 CTE 名前）是否换行"
                },
                "Hive-Formatter.indentCteBody": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "CTE 子查询体是否相对于 AS ( 缩进一级"
                },
                "Hive-Formatter.newlineBetweenCtes": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "多个 CTE 之间是否插入独立空行分隔"
                },
                "Hive-Formatter.cteCommaPosition": {
                    "type": "string",
                    "enum": ["before", "after"],
                    "default": "before",
                    "markdownDescription": "CTE 定义之间的逗号位于行首还是行尾"
                },
                "Hive-Formatter.newlineAfterOver": {
                    "type": "boolean",
                    "default": false,
                    "markdownDescription": "OVER( 后是否换行"
                },
                "Hive-Formatter.newlineBeforePartitionBy": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "PARTITION BY 前是否换行"
                },
                "Hive-Formatter.newlineAfterPartitionBy": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "PARTITION BY 后是否换行"
                },
                "Hive-Formatter.newlineBeforeOrderByInWindow": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "窗口内 ORDER BY 前是否换行"
                },
                "Hive-Formatter.indentJoinConditions": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "JOIN ON 后的条件是否相对于 JOIN 缩进一级"
                },
                "Hive-Formatter.alignOnClauses": {
                    "type": "boolean",
                    "default": false,
                    "markdownDescription": "ON 条件中多个 AND/OR 条件关键字是否对齐"
                },
                "Hive-Formatter.alignInsertColumns": {
                    "type": "boolean",
                    "default": false,
                    "markdownDescription": "INSERT 列名列表与 VALUES 值列表是否列对齐"
                },
                "Hive-Formatter.alignInsertValuesGroups": {
                    "type": "boolean",
                    "default": false,
                    "markdownDescription": "多行 VALUES 组之间的值是否对齐"
                },
                "Hive-Formatter.newlineAfterInsert": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "INSERT INTO 关键字后是否换行"
                },
                "Hive-Formatter.newlineAfterInsertColumns": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "列名列表的闭括号后、VALUES 前是否换行"
                },
                "Hive-Formatter.newlineBetweenValuesGroups": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "多行 VALUES 组之间是否换行分隔"
                },
                "Hive-Formatter.newlineAfterCase": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "CASE 关键字后是否换行"
                },
                "Hive-Formatter.newlineAfterWhen": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "WHEN 条件表达式后是否换行"
                },
                "Hive-Formatter.newlineAfterThen": {
                    "type": "boolean",
                    "default": false,
                    "markdownDescription": "THEN 后的结果表达式是否换行"
                },
                "Hive-Formatter.newlineAfterElse": {
                    "type": "boolean",
                    "default": false,
                    "markdownDescription": "ELSE 后的结果表达式是否换行"
                },
                "Hive-Formatter.indentWhen": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "WHEN 关键字是否相对于 CASE 缩进一级"
                },
                "Hive-Formatter.indentThen": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "THEN 关键字是否相对于 WHEN 缩进一级"
                },
                "Hive-Formatter.newlineAfterIn": {
                    "type": "boolean",
                    "default": false,
                    "markdownDescription": "IN ( 后是否换行"
                },
                "Hive-Formatter.maxItemsInlineList": {
                    "type": "number",
                    "default": 5,
                    "minimum": 1,
                    "markdownDescription": "IN / VALUES 列表项数超过此阈值时强制换行"
                },
                "Hive-Formatter.subqueryParenStyle": {
                    "type": "string",
                    "enum": ["inline", "newline"],
                    "default": "inline",
                    "markdownDescription": "子查询左括号是否与内容同行"
                },
                "Hive-Formatter.commentPosition": {
                    "type": "string",
                    "enum": ["preserve", "newline", "inline"],
                    "default": "preserve",
                    "markdownDescription": "格式化后行内注释的放置策略"
                },
                "Hive-Formatter.blankLinesBeforeSetOperation": {
                    "type": "number",
                    "default": 1,
                    "minimum": 0,
                    "markdownDescription": "UNION / INTERSECT / EXCEPT 前插入的空行数"
                },
                "Hive-Formatter.blankLinesAfterSetOperation": {
                    "type": "number",
                    "default": 0,
                    "minimum": 0,
                    "markdownDescription": "UNION / INTERSECT / EXCEPT 后插入的空行数"
                },
                "Hive-Formatter.newlineBeforeLateralView": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "LATERAL VIEW 前是否换行（Hive 方言）"
                },
                "Hive-Formatter.newlineBeforeDistributeBy": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "DISTRIBUTE BY 前是否换行（Hive 方言）"
                },
                "Hive-Formatter.newlineBeforeClusterBy": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "CLUSTER BY 前是否换行（Hive 方言）"
                },
                "Hive-Formatter.newlineBeforeSortBy": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "SORT BY 前是否换行（Hive 方言）"
                },
                "Hive-Formatter.newlineBeforeConnectBy": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "CONNECT BY 前是否换行（Oracle 方言）"
                },
                "Hive-Formatter.newlineBeforeStartWith": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "START WITH 前是否换行（Oracle 方言）"
                }
            }
        },
        "menus": {
            "editor/context": [
                {
                    "command": "hive-formatter.toggleComment",
                    "when": "editorLangId =~ /sql|hive/",
                    "group": "1_comment@1"
                },
                {
                    "command": "hive-formatter.toggleAdvancedComment",
                    "when": "editorLangId =~ /sql|hive/",
                    "group": "1_comment@2"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/nearley": "^2.11.5",
        "@types/node": "22.x",
        "@types/vscode": "^1.85.0",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.5.2",
        "@vscode/vsce": "^3.9.1",
        "eslint": "^9.39.2",
        "eslint-plugin-tsdoc": "^0.5.0",
        "jiti": "^2.6.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.52.0"
    },
    "dependencies": {
        "nearley": "^2.20.1"
    }
}
